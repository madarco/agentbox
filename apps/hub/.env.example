# --- AgentBox hosted control plane ---

# Postgres (Vercel Postgres / Neon / a self-hosted container). Required.
POSTGRES_URL=postgres://postgres:pw@localhost:5432/postgres

# Admin bearer gating /admin/* and /remote/*. Required (fails closed if unset).
# Generate one: `openssl rand -hex 32`
AGENTBOX_RELAY_ADMIN_TOKEN=

# GitHub App (for git.lease-token). Optional — without it, leasing returns a
# clear "not configured" error and the plane still serves events/registry/etc.
# GITHUB_APP_PRIVATE_KEY may be a raw PEM or base64-encoded PEM.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
# Optional: GitHub Enterprise API base (defaults to https://api.github.com).
# GITHUB_API_URL=

# --- Hub profile + auth ---

# Which profile the hub runs as: localhost | hetzner | vercel.
# The embedded server (server.ts) defaults this from the bind host
# (127.0.0.1 -> localhost, else hetzner); set it explicitly for vercel.
AGENTBOX_HUB_PROFILE=vercel

# Auth toggle. Unset means: localhost uses the token gate (see below), and
# hetzner/vercel use password login. Set to `off` to disable ALL protection.
AGENTBOX_HUB_AUTH=on

# localhost only: the token gate is a shared-secret cookie (no login screen).
# server.ts auto-generates ~/.agentbox/hub/token on first run and opens the UI
# with `?token=<secret>`; you never set this by hand. AGENTBOX_HUB_AUTH=off
# disables it. (AGENTBOX_HUB_TOKEN is provisioned by server.ts, not configured.)

# better-auth signing secret. Required when auth is on. Generate one:
# `openssl rand -base64 32` (must be >= 32 chars).
BETTER_AUTH_SECRET=

# Seed a single admin on first boot / on db:auth-migrate (idempotent). Password
# must be >= 8 chars. Not needed on localhost (auth off).
AGENTBOX_HUB_ADMIN_EMAIL=
AGENTBOX_HUB_ADMIN_PASSWORD=

# Optional: pin the auth base URL / trusted origin (else the request origin is
# trusted — fine for a single-origin self-hosted hub).
# BETTER_AUTH_URL=https://hub.example.com
