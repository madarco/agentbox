{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-box.sh/schema/user-config.schema.json",
  "title": "AgentBox user config",
  "description": "Layered defaults for the agentbox CLI. Same shape lives in ~/.agentbox/config.yaml (global), ~/.agentbox/projects/<hash>/config.yaml (per-project user), and the `defaults:` block of agentbox.yaml (committed project policy).",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "box": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hostSnapshot": { "type": "boolean" },
        "defaultCheckpoint": { "type": "string", "minLength": 1 },
        "defaultCheckpointDocker": { "type": "string", "minLength": 1 },
        "defaultCheckpointDaytona": { "type": "string", "minLength": 1 },
        "defaultCheckpointHetzner": { "type": "string", "minLength": 1 },
        "defaultCheckpointVercel": { "type": "string", "minLength": 1 },
        "defaultCheckpointE2b": { "type": "string", "minLength": 1 },
        "size": { "type": "string", "minLength": 1 },
        "sizeDocker": { "type": "string", "minLength": 1 },
        "sizeDaytona": { "type": "string", "minLength": 1 },
        "sizeHetzner": { "type": "string", "minLength": 1 },
        "sizeVercel": { "type": "string", "minLength": 1 },
        "sizeE2b": { "type": "string", "minLength": 1 },
        "withPlaywright": { "type": "boolean" },
        "withEnv": { "type": "boolean" },
        "resyncOnStart": { "type": "boolean" },
        "vnc": { "type": "boolean" },
        "autoApproveHostActions": { "type": "boolean" },
        "isolateClaudeConfig": { "type": "boolean" },
        "isolateCodexConfig": { "type": "boolean" },
        "isolateOpencodeConfig": { "type": "boolean" },
        "image": { "type": "string", "minLength": 1 },
        "imageDocker": { "type": "string", "minLength": 1 },
        "imageDaytona": { "type": "string", "minLength": 1 },
        "imageHetzner": { "type": "string", "minLength": 1 },
        "imageVercel": { "type": "string", "minLength": 1 },
        "imageE2b": { "type": "string", "minLength": 1 },
        "dockerCacheShared": { "type": "boolean" },
        "memory": { "type": "integer", "minimum": 0 },
        "cpus": { "type": "integer", "minimum": 0 },
        "pidsLimit": { "type": "integer", "minimum": 0 },
        "disk": { "type": "string" },
        "bundleDepth": { "type": "integer", "minimum": 0 },
        "vercelVcpus": { "type": "integer", "minimum": 1 },
        "vercelTimeoutMs": { "type": "integer", "minimum": 1 },
        "vercelNetworkPolicy": { "type": "string" },
        "cpMaxBytes": { "type": "integer", "minimum": 1 }
      }
    },
    "checkpoint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxLayers": { "type": "integer" }
      }
    },
    "claude": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sessionName": { "type": "string", "minLength": 1 }
      }
    },
    "codex": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sessionName": { "type": "string", "minLength": 1 }
      }
    },
    "opencode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sessionName": { "type": "string", "minLength": 1 }
      }
    },
    "attach": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "openIn": { "enum": ["split", "window", "tab", "same"] },
        "cmuxStatus": { "type": "boolean" }
      }
    },
    "code": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ide": { "enum": ["vscode", "cursor", "auto"] },
        "wait": { "type": "boolean" },
        "timeoutMs": { "type": "integer" },
        "autoTerminals": { "type": "boolean" }
      }
    },
    "shell": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "user": { "type": "string", "minLength": 1 },
        "login": { "type": "boolean" },
        "tmux": { "type": "boolean" }
      }
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["orbstack", "docker-desktop", "other", "auto"] }
      }
    },
    "browser": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default": { "enum": ["agent-browser", "playwright", "both"] }
      }
    },
    "relay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": { "type": "integer" }
      }
    },
    "vnc": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "containerPort": { "type": "integer" }
      }
    },
    "portless": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "stateDir": { "type": "string", "minLength": 1 }
      }
    },
    "autopause": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "maxRunningBoxes": { "type": "integer" },
        "idleMinutes": { "type": "integer" }
      }
    },
    "queue": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "maxConcurrent": { "type": "integer" },
        "maxWorking": { "type": "integer" },
        "idleGraceSeconds": { "type": "integer" },
        "openIn": { "enum": ["none", "split", "window", "tab"] }
      }
    },
    "maintenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pruneProjectConfigs": { "type": "boolean" },
        "pruneProjectConfigsEvery": { "type": "integer" }
      }
    }
  }
}
