{
  "name": "@agentbox/ctl",
  "version": "0.0.0",
  "private": true,
  "description": "In-container supervisor daemon and CLI for AgentBox",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bin": "./dist/bin.cjs"
  },
  "bin": {
    "agentbox-ctl": "./dist/bin.cjs"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@agentbox/core": "workspace:*",
    "@agentbox/integrations": "workspace:*",
    "@agentbox/relay": "workspace:*",
    "commander": "^12.1.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "ajv": "^8.17.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@agentbox/sandbox-core": "workspace:*"
  }
}
