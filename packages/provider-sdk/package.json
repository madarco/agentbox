{
  "name": "@madarco/agentbox-provider-sdk",
  "version": "2.4.0",
  "description": "Public SDK for building AgentBox sandbox providers as installable community packages",
  "license": "MIT",
  "author": "Marco D'Alia",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "agentbox",
    "provider",
    "plugin",
    "sdk",
    "sandbox",
    "coding-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madarco/agentbox.git",
    "directory": "packages/provider-sdk"
  },
  "homepage": "https://github.com/madarco/agentbox/blob/main/docs/provider-plugins.md",
  "bugs": {
    "url": "https://github.com/madarco/agentbox/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "pack:test": "node scripts/pack-test.mjs",
    "prepublishOnly": "pnpm build",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "execa": "^9.5.2",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@agentbox/config": "workspace:*",
    "@agentbox/core": "workspace:*",
    "@agentbox/sandbox-cloud": "workspace:*",
    "@agentbox/sandbox-core": "workspace:*",
    "@types/node": "^22.10.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
