{
  "name": "@agentbox/sandbox-cloud",
  "version": "0.0.0",
  "private": true,
  "description": "Cloud-common provider scaffolding: composes a full Provider from a thin CloudBackend",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@agentbox/config": "workspace:*",
    "@agentbox/core": "workspace:*",
    "@agentbox/sandbox-core": "workspace:*",
    "@agentbox/sandbox-docker": "workspace:*",
    "execa": "^9.5.2",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
